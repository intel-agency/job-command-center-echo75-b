{
  // ===================================================================
  // Serilog Configuration
  // ===================================================================
  // This configuration uses structured logging with automatic enrichment.
  // See AGENTS.md for logging conventions and best practices.
  // ===================================================================
  "Serilog": {
    // Minimum log level for the application
    // Options: Verbose, Debug, Information, Warning, Error, Fatal
    "MinimumLevel": {
      "Default": "Information",
      // Namespace-specific log level overrides
      // Reduce noise from framework libraries while preserving important logs
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning",
        // Entity Framework Core - reduce query logging noise
        "Microsoft.EntityFrameworkCore": "Warning",
        // Keep hosting lifetime events for startup/shutdown visibility
        "Microsoft.Hosting.Lifetime": "Information",
        // HTTP client logging
        "System.Net.Http": "Warning"
      }
    },
    // Output sinks configuration
    "WriteTo": [
      // Console sink - always enabled for visibility
      {
        "Name": "Console",
        "Args": {
          // ANSI theme provides colored output in terminals that support it
          // Options: "Ansi" (colored), "None" (no colors), "Code" (VS Code theme)
          "theme": "Ansi",
          // Output template with structured format
          // Available placeholders: Timestamp, Level, Message, SourceContext, Exception
          // :lj format specifier renders message as literal JSON
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj}{NewLine}    └─ {SourceContext}{NewLine}{Exception}"
        }
      },
      // File sink - rolling log files with retention policy
      {
        "Name": "File",
        "Args": {
          // Log file path with rolling pattern
          // The hyphen before .log enables daily rolling (jcc-20250316.log)
          "path": "logs/web-.log",
          // Rolling interval: Minute, Hour, Day, Month, Year
          "rollingInterval": "Day",
          // Number of log files to retain (1-90 days)
          "retainedFileCountLimit": 7,
          // Output template with full timestamp and timezone
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] [{SourceContext}] {Message:lj}{NewLine}{Exception}",
          // Allow multiple processes to write to the same log file
          "shared": true,
          // Flush to disk interval for durability
          "flushToDiskInterval": "00:00:01"
        }
      }
    ],
    // Enrichers add additional properties to all log events
    // These are configured programmatically in SerilogConfiguration.cs
    "Enrich": [
      "FromLogContext",
      "WithThreadId",
      "WithProcessId",
      "WithMachineName"
    ],
    // Filter configuration (optional)
    "Filter": [
      {
        "Name": "ByExcluding",
        "Args": {
          // Exclude health check logs from flooding the logs
          "expression": "RequestPath like '/health%'"
        }
      }
    ]
  },
  // ===================================================================
  // Service Identity Configuration
  // ===================================================================
  // Used for log enrichment and OpenTelemetry resource attributes
  "Service": {
    "Name": "JobCommandCenter.Web",
    "Version": "1.0.0"
  },
  // ===================================================================
  // OpenTelemetry Configuration (optional)
  // ===================================================================
  // Uncomment to enable OTLP export to a collector like Jaeger or Grafana
  // "OTEL_EXPORTER_OTLP_ENDPOINT": "http://localhost:4317",
  // "OTEL_SERVICE_NAME": "JobCommandCenter.Web",
  // "OTEL_EXPORTER_OTLP_PROTOCOL": "grpc",
  // ===================================================================
  // ASP.NET Core Configuration
  // ===================================================================
  "AllowedHosts": "*",
  // Disable file sink in containerized environments (logs go to stdout)
  // Set to true if running in Docker with log driver configured
  "Containerized": false
}
