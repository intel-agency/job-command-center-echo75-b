@page "/"

<PageTitle>Job Command Center - Dashboard</PageTitle>

<MudText H4 Class="mb-4">Job Command Center Dashboard</MudText>

<MudGrid>
    <MudItem xs="12" md="3">
        <MudPaper Elevation="2" Class="pa-4">
            <MudText Subtitle2 Color="Color.Secondary">Total Found</MudText>
            <MudText H3>0</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" md="3">
        <MudPaper Elevation="2" Class="pa-4">
            <MudText Subtitle2 Color="Color.Secondary">Top Matches</MudText>
            <MudText H3>0</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" md="3">
        <MudPaper Elevation="2" Class="pa-4">
            <MudText Subtitle2 Color="Color.Secondary">Pending</MudText>
            <MudText H3>0</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" md="3">
        <MudPaper Elevation="2" Class="pa-4">
            <MudText Subtitle2 Color="Color.Secondary">Applied</MudText>
            <MudText H3>0</MudText>
        </MudPaper>
    </MudItem>
</MudGrid>

<MudDivider Class="my-4" />

<MudText H5 Class="mb-2">Jobs Pipeline</MudText>
<MudAlert Severity="Severity.Info" Class="mb-4">
    No jobs have been harvested yet. Start Chrome with <code>--remote-debugging-port=9222</code> and launch the Harvester service.
</MudAlert>
