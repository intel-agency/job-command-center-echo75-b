{
  // ===================================================================
  // Development Serilog Configuration
  // ===================================================================
  // More verbose logging for development and debugging.
  // This file overrides settings in appsettings.json.
  // ===================================================================
  "Serilog": {
    // More verbose default level for development
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        // Show more framework details in development
        "Microsoft": "Information",
        "System": "Information",
        // Entity Framework - show queries for debugging
        "Microsoft.EntityFrameworkCore.Database.Command": "Information",
        "Microsoft.EntityFrameworkCore.Query": "Debug",
        // Hosting lifetime events
        "Microsoft.Hosting.Lifetime": "Information",
        // HTTP client - show request details
        "System.Net.Http": "Information",
        // Playwright - show browser automation details
        "Microsoft.Playwright": "Debug"
      }
    },
    // Additional console output in development
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "theme": "Ansi",
          // More detailed output template for development
          "outputTemplate": "[{Timestamp:HH:mm:ss.fff} {Level:u3}] [{SourceContext}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  },
  // ===================================================================
  // Development Service Configuration
  // ===================================================================
  "Service": {
    "Name": "JobCommandCenter.Harvester.Development",
    "Version": "1.0.0-dev"
  },
  // ===================================================================
  // Development OpenTelemetry Configuration
  // ===================================================================
  // Enable OTLP export to local collector for debugging
  // "OTEL_EXPORTER_OTLP_ENDPOINT": "http://localhost:4317",
  // "OTEL_SERVICE_NAME": "JobCommandCenter.Harvester.Dev",
  // ===================================================================
  // Development Harvester Configuration
  // ===================================================================
  "Harvester": {
    "Chrome": {
      "RemoteDebuggingPort": 9222,
      "ConnectionTimeoutSeconds": 60,
      "NavigationTimeoutSeconds": 120
    },
    "Schedule": {
      // Shorter interval for testing
      "IntervalMinutes": 1,
      "JitterSeconds": 5
    },
    "RateLimit": {
      // Faster for development testing (still safe)
      "MinDelayMs": 200,
      "MaxDelayMs": 500,
      "MaxRequestsPerMinute": 20
    }
  }
}
